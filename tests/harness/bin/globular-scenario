#!/usr/bin/env python3
"""
globular-scenario — YAML scenario executor for Globular V1 test harness.

Usage: globular-scenario <scenario.yaml> <output-dir> [--verbose]

Parses a scenario YAML file and executes its sections in order:
  preconditions → baseline → steps → assertions → cleanup

Each probe/action maps to a bash function in tests/harness/lib/probes.sh.
Results are collected as JSON evidence and a markdown summary is written
to <output-dir>/evidence.json and <output-dir>/RESULT.md.

Exit code: 0 = PASS, 1 = FAIL
"""

import sys
import os
import json
import subprocess
import datetime
import time
import shlex
import warnings

warnings.filterwarnings("ignore", category=DeprecationWarning)

try:
    import yaml
except ImportError:
    print("ERROR: pyyaml required. Run: pip3 install pyyaml", file=sys.stderr)
    sys.exit(1)

HARNESS_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
LIB_DIR = os.path.join(HARNESS_DIR, "lib")
PROBES_SH = os.path.join(LIB_DIR, "probes.sh")
AWARENESS_SH = os.path.join(LIB_DIR, "awareness.sh")
EVIDENCE_SH = os.path.join(LIB_DIR, "evidence.sh")
TRAINING_SH = os.path.join(LIB_DIR, "training.sh")
LEDGER_FILE = os.path.join(
    os.path.dirname(HARNESS_DIR), "reports", "awareness-training-ledger.jsonl"
)


class AwarenessCollector:
    """
    Calls awareness.sh functions to collect evidence before/after a scenario.
    All calls are non-fatal — awareness failures never hide scenario failures.
    """

    def __init__(self, cfg: dict, output_dir: str):
        self.cfg = cfg or {}
        self.output_dir = output_dir
        self.enabled = bool(self.cfg.get("enabled", False))
        self.task = self.cfg.get("task", "")
        self.phase = self.cfg.get("phase", "")
        self.include_runtime = bool(self.cfg.get("include_runtime",
            os.environ.get("AWARENESS_INCLUDE_RUNTIME", "0") == "1"))
        self.runtime_window = self.cfg.get("runtime_window",
            os.environ.get("AWARENESS_RUNTIME_WINDOW", "30m"))
        self.create_incident = bool(self.cfg.get("create_incident_on_failure", False))
        self.create_proposal = bool(self.cfg.get("create_proposal_on_failure", False))
        self.expected_failure_modes = self.cfg.get("expected_failure_modes", [])
        training = self.cfg.get("training", {}) or {}
        self.training_enabled = bool(training.get("enabled",
            os.environ.get("AWARENESS_TRAINING", "0") == "1"))
        self._had_error = False
        self.patterns_cfg = self.cfg.get("patterns") or {}
        self.patterns_validate = self.patterns_cfg.get("validate") or []
        self.expected_invariants_for_patterns = self.patterns_cfg.get("expected_invariants") or []
        self.expected_code_smells_absent = self.patterns_cfg.get("expected_code_smells_absent") or []
        self._pattern_result = "SKIPPED"

    def _run(self, func: str, *args) -> bool:
        """Source awareness.sh and call func with args via bash. Returns True on success."""
        if not os.path.exists(AWARENESS_SH):
            return False
        quoted = " ".join(shlex.quote(str(a)) for a in args)
        cmd = f'source "{AWARENESS_SH}" && {func} {quoted}'
        try:
            proc = subprocess.run(["bash", "-c", cmd], timeout=180)
            return proc.returncode == 0
        except subprocess.TimeoutExpired:
            print(f"  [awareness] WARNING: {func} timed out after 180s")
            self._had_error = True
            return False
        except Exception as e:
            print(f"  [awareness] WARNING: {func} error: {e}")
            self._had_error = True
            return False

    def preflight(self) -> None:
        if self.task:
            ok = self._run("awareness_preflight", self.task, self.phase, self.output_dir,
                           "1" if self.include_runtime else "0", self.runtime_window)
            if not ok:
                skipped = os.path.join(self.output_dir, "awareness", "SKIPPED.txt")
                if not os.path.exists(skipped):
                    self._had_error = True

    def runtime_snapshot(self) -> None:
        if self.enabled and self.include_runtime:
            self._run("awareness_runtime_snapshot", self.output_dir)

    def on_failure(self) -> None:
        if not self.task:
            return
        self._run("awareness_debug_session", self.task, self.phase, self.output_dir)
        self._run("awareness_did_we_fix", self.task, self.output_dir)
        want_incident = self.create_incident or self.training_enabled
        if want_incident:
            self._run("awareness_incident_from_failure", self.task, self.output_dir)
            if self.create_proposal:
                self._run("awareness_propose_from_incident", self.output_dir)

    def collect_patterns(self) -> str:
        """Collect pattern evidence. Returns 'PASS', 'WARN', 'SKIPPED', or 'FAIL'."""
        if not self.patterns_validate:
            return "SKIPPED"
        patterns_csv = ",".join(self.patterns_validate)
        preflight_json = os.path.join(self.output_dir, "awareness", "preflight.json")
        preflight_arg = preflight_json if os.path.exists(preflight_json) else ""
        self._run("awareness_collect_patterns", patterns_csv, self.output_dir, preflight_arg)
        val_file = os.path.join(self.output_dir, "awareness", "patterns", "validation.json")
        if not os.path.exists(val_file):
            return "SKIPPED"
        try:
            with open(val_file) as f:
                val = json.load(f)
            return val.get("overall_result", "SKIPPED")
        except Exception:
            return "WARN"

    def get_result(self) -> str:
        """Return AWARENESS_PASS, AWARENESS_SKIPPED, or AWARENESS_ERROR."""
        adir = os.path.join(self.output_dir, "awareness")
        if not os.path.isdir(adir):
            return "AWARENESS_SKIPPED"
        if os.path.exists(os.path.join(adir, "SKIPPED.txt")):
            return "AWARENESS_SKIPPED"
        if self._had_error:
            return "AWARENESS_ERROR"
        for artifact in ["preflight.agent.txt", "preflight.json",
                         "debug-session.agent.txt", "debug-session.json"]:
            if os.path.exists(os.path.join(adir, artifact)):
                return "AWARENESS_PASS"
        return "AWARENESS_SKIPPED"


class EvidenceCollector:
    """Calls evidence.sh to collect full cluster state after scenario failure."""

    def __init__(self, output_dir: str):
        self.output_dir = output_dir

    def collect(self, scenario_file: str = "", result_json_path: str = "") -> None:
        if not os.path.exists(EVIDENCE_SH):
            return
        args = [shlex.quote(self.output_dir)]
        if scenario_file:
            args.append(shlex.quote(scenario_file))
        if result_json_path:
            args.append(shlex.quote(result_json_path))
        cmd = f'source "{EVIDENCE_SH}" && evidence_collect_all {" ".join(args)}'
        try:
            subprocess.run(["bash", "-c", cmd], timeout=180)
        except subprocess.TimeoutExpired:
            print("  [evidence] WARNING: collection timed out after 180s")
        except Exception as e:
            print(f"  [evidence] WARNING: collection error: {e}")


class Evidence:
    def __init__(self, scenario_name: str, suite: str):
        self.scenario_name = scenario_name
        self.suite = suite
        self.start_time = datetime.datetime.utcnow()
        self.items: list = []
        self.passed = True

    def record(self, section: str, item_id: str, probe: str, params: dict,
               expect: dict, result: dict, passed: bool):
        self.items.append({
            "id": item_id,
            "section": section,
            "probe": probe,
            "params": params,
            "expect": expect,
            "result": result,
            "passed": passed,
            "timestamp": datetime.datetime.utcnow().isoformat() + "Z",
        })
        if not passed:
            self.passed = False

    def to_dict(self) -> dict:
        return {
            "schema_version": 1,
            "scenario": self.scenario_name,
            "suite": self.suite,
            "start_time": self.start_time.isoformat() + "Z",
            "end_time": datetime.datetime.utcnow().isoformat() + "Z",
            "passed": self.passed,
            "item_count": len(self.items),
            "items": self.items,
        }


class ScenarioExecutor:
    def __init__(self, scenario_file: str, output_dir: str, verbose: bool = False):
        self.scenario_file = scenario_file
        self.output_dir = output_dir
        self.verbose = verbose

        with open(scenario_file) as f:
            self.scenario = yaml.safe_load(f)

        name = self.scenario.get("name", os.path.basename(scenario_file))
        suite = self.scenario.get("suite", "unknown")
        self.evidence = Evidence(name, suite)
        self.baseline_captures: dict = {}
        self.awareness = AwarenessCollector(
            self.scenario.get("awareness", {}), output_dir)
        self.evidence_collector = EvidenceCollector(output_dir)

    # ── public entry point ────────────────────────────────────────────────────

    def run(self) -> bool:
        name = self.scenario.get("name", "?")
        desc = self.scenario.get("description", "")
        print(f"  Scenario: {name}")
        if desc:
            print(f"  {desc}")

        if not self._validate_schema():
            return False

        # Check cluster reachability for INFRA_ERROR classification.
        cluster_ok = self._cluster_reachable()
        if not cluster_ok:
            print("  [WARNING] Cluster nodes not reachable — running in degraded mode")

        # Awareness preflight — before any scenario sections run.
        self.awareness.preflight()
        # Collect pattern evidence immediately after preflight (while graph is warm).
        self.awareness._pattern_result = self.awareness.collect_patterns()

        # Execute sections in order. Stop early on precondition or assertion failure,
        # but ALWAYS run cleanup regardless of earlier failures so chaos tests can
        # restore cluster state even when assertions expose a catastrophic failure.
        sections = [
            ("preconditions", self._exec_probes, True),   # stop on fail
            ("baseline",      self._exec_probes, False),  # capture only
            ("steps",         self._exec_steps,  False),  # actions
            ("assertions",    self._exec_probes, True),   # stop on fail (cleanup still runs)
            ("cleanup",       self._exec_steps,  False),  # always runs — best-effort restore
        ]

        overall_ok = True
        stopped_at = None
        steps_ok = True
        for section, handler, stop_on_fail in sections:
            items = self.scenario.get(section, [])
            if not items:
                continue
            # Skip intermediate sections if stopped, but ALWAYS run cleanup
            if stopped_at and section != "cleanup":
                print(f"  [SKIP] {section} (stopped at {stopped_at})")
                continue
            print(f"  [{section}]")
            ok = handler(items, section)
            if section == "steps" and not ok:
                steps_ok = False
            if not ok:
                overall_ok = False
                if stop_on_fail and stopped_at is None:
                    stopped_at = section
                    print(f"  STOPPED: {section} failed — cleanup will still run")

        # Determine result classification.
        if not cluster_ok and not overall_ok and stopped_at == "preconditions":
            result = "INFRA_ERROR"
        elif not overall_ok and steps_ok and stopped_at == "assertions":
            result = "FAIL"
        elif not overall_ok and not steps_ok:
            result = "PARTIAL"
        else:
            result = "PASS" if overall_ok else "FAIL"

        # Awareness post-scenario collection.
        self.awareness.runtime_snapshot()
        if not overall_ok:
            self.awareness.on_failure()
            result_json_path = os.path.join(self.output_dir, "evidence.json")
            self.evidence_collector.collect(self.scenario_file, result_json_path)

        awareness_result = self.awareness.get_result()
        self._write_output(overall_ok, result, awareness_result)
        self._append_to_ledger(result, awareness_result)
        return overall_ok

    def _cluster_reachable(self) -> bool:
        """Quick check if globular-node-1 container is running."""
        try:
            proc = subprocess.run(
                ["docker", "inspect", "globular-node-1",
                 "--format", "{{.State.Running}}"],
                capture_output=True, text=True, timeout=10)
            return proc.returncode == 0 and proc.stdout.strip() == "true"
        except Exception:
            return False

    # ── section handlers ──────────────────────────────────────────────────────

    def _exec_probes(self, items: list, section: str) -> bool:
        ok = True
        for item in items:
            if item.get("type") not in ("probe", None):
                continue
            if not self._exec_probe_item(item, section):
                ok = False
        return ok

    def _exec_steps(self, items: list, section: str) -> bool:
        ok = True
        for item in items:
            action = item.get("action", "")
            item_id = item.get("id", action or "step")

            if action == "wait":
                if self._exec_wait(item, section):
                    print(f"    OK:   {item_id}")
                else:
                    print(f"    FAIL: {item_id} (wait timed out)")
                    ok = False

            elif action.startswith("chaos."):
                if self._exec_chaos(item, section):
                    print(f"    OK:   {item_id}")
                else:
                    print(f"    FAIL: {item_id} ({action} failed)")
                    ok = False

            elif action in ("publish.service_package", "repository.promote",
                            "desired_state.upsert", "workflow.dispatch",
                            "backup.create", "backup.restore",
                            "node.recover.full_reseed"):
                print(f"    SKIP: {item_id} ({action} — not yet implemented)")

            elif item.get("probe"):
                # Step is actually a probe-style check
                if not self._exec_probe_item(item, section):
                    ok = False

            else:
                print(f"    SKIP: {item_id} (unknown action: {action})")

        return ok

    # ── probe execution ───────────────────────────────────────────────────────

    def _exec_probe_item(self, item: dict, section: str) -> bool:
        probe = item.get("probe", "")
        params = item.get("params", {}) or {}
        expect = item.get("expect", {}) or {}
        item_id = item.get("id") or probe or "probe"

        if not probe:
            print(f"    SKIP: {item_id} (no probe specified)")
            return True

        result = self._call_probe(probe, params)

        if self.verbose:
            print(f"    result: {json.dumps(result)}")

        if expect:
            passed, failures = self._check_expect(result, expect)
        else:
            # No expect — just a capture (baseline)
            passed = True
            failures = []
            self.baseline_captures[item_id] = result

        status = "PASS" if passed else "FAIL"
        print(f"    {status}: {item_id}")
        if not passed:
            for f in failures:
                print(f"      {f}")

        self.evidence.record(section, item_id, probe, params, expect, result, passed)
        return passed

    def _exec_wait(self, item: dict, section: str) -> bool:
        params = item.get("params", {}) or {}
        timeout = int(params.get("timeout", 60))
        poll_interval = int(params.get("poll_interval", 5))
        until = params.get("until") or {}
        item_id = item.get("id", "wait")

        if not until:
            # Plain sleep — honour the configured timeout
            print(f"    WAIT: {item_id} (sleeping {timeout}s)")
            time.sleep(timeout)
            return True

        probe = until.get("probe", "")
        probe_params = until.get("params", {}) or {}
        expect = until.get("expect", {}) or {}

        deadline = time.time() + timeout
        attempt = 0
        while time.time() < deadline:
            attempt += 1
            result = self._call_probe(probe, probe_params)
            passed, _ = self._check_expect(result, expect)
            if passed:
                self.evidence.record(
                    section, item_id, probe, probe_params, expect, result, True)
                return True
            remaining = int(deadline - time.time())
            print(f"    WAIT: {item_id} (attempt {attempt}, {remaining}s remaining)")
            time.sleep(poll_interval)

        result = self._call_probe(probe, probe_params)
        self.evidence.record(
            section, item_id, probe, probe_params, expect, result, False)
        return False

    # ── chaos execution ───────────────────────────────────────────────────────

    def _exec_chaos(self, item: dict, section: str) -> bool:
        """
        Execute a chaos action. Supported actions:
          chaos.stop_node      params: node (e.g. "node-4")
          chaos.start_node     params: node
          chaos.kill_service   params: node, service (systemd unit suffix)
          chaos.restart_service params: node, service
        All run docker commands on the host (not inside a container).
        """
        action = item.get("action", "")
        params = item.get("params", {}) or {}
        item_id = item.get("id", action)

        node = params.get("node", "")
        service = params.get("service", "")
        container = f"globular-{node}" if node else ""

        if self.verbose:
            print(f"    [chaos] {action} node={node} service={service}")

        try:
            if action == "chaos.stop_node":
                if not container:
                    return self._chaos_fail(section, item_id, action, params, "node param required")
                # Use docker stop -t 10 so Docker sends SIGTERM then SIGKILL after 10s.
                # The compose stop_grace_period (30s) governs systemd shutdown, but for
                # chaos testing we want a fast, forced stop. Timeout 20s > -t 10 so the
                # Python subprocess never races the docker stop grace period.
                proc = subprocess.run(
                    ["docker", "stop", "-t", "10", container],
                    capture_output=True, text=True, timeout=20)
                ok = proc.returncode == 0
                result = {"action": action, "container": container,
                          "exit_code": proc.returncode,
                          "stdout": proc.stdout.strip()[:100]}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.start_node":
                if not container:
                    return self._chaos_fail(section, item_id, action, params, "node param required")
                proc = subprocess.run(
                    ["docker", "start", container],
                    capture_output=True, text=True, timeout=30)
                ok = proc.returncode == 0
                result = {"action": action, "container": container,
                          "exit_code": proc.returncode,
                          "stdout": proc.stdout.strip()[:100]}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.kill_service":
                # Graceful stop (SIGTERM). Use chaos.sigkill_service for SIGKILL.
                if not container or not service:
                    return self._chaos_fail(section, item_id, action, params, "node and service params required")
                unit = f"globular-{service}.service"
                proc = subprocess.run(
                    ["docker", "exec", container, "systemctl", "stop", unit],
                    capture_output=True, text=True, timeout=30)
                ok = proc.returncode == 0
                result = {"action": action, "container": container, "unit": unit,
                          "exit_code": proc.returncode,
                          "stderr": proc.stderr.strip()[:200]}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.sigkill_service":
                # Hard kill — sends SIGKILL to main process, triggering Restart=on-failure.
                if not container or not service:
                    return self._chaos_fail(section, item_id, action, params, "node and service params required")
                unit = f"globular-{service}.service"
                proc = subprocess.run(
                    ["docker", "exec", container, "systemctl", "kill",
                     "--kill-who=main", "-s", "KILL", unit],
                    capture_output=True, text=True, timeout=30)
                ok = proc.returncode == 0
                result = {"action": action, "container": container, "unit": unit,
                          "signal": "SIGKILL", "exit_code": proc.returncode,
                          "stderr": proc.stderr.strip()[:200]}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.restart_service":
                if not container or not service:
                    return self._chaos_fail(section, item_id, action, params, "node and service params required")
                unit = f"globular-{service}.service"
                # Use --no-block so systemctl returns immediately without waiting
                # for the service to reach 'active'. Services using Type=notify
                # (e.g. cluster-controller) may never reach 'active' if the binary
                # does not call sd_notify(READY=1) — causing systemctl to hang
                # indefinitely without --no-block.
                proc = subprocess.run(
                    ["docker", "exec", container, "systemctl", "restart", "--no-block", unit],
                    capture_output=True, text=True, timeout=30)
                ok = proc.returncode == 0
                result = {"action": action, "container": container, "unit": unit,
                          "exit_code": proc.returncode,
                          "stderr": proc.stderr.strip()[:200]}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.fill_disk":
                # Fill disk on a node to a target usage percentage.
                # params: node, path (default /var/lib/globular), target_pct (default 95)
                if not container:
                    return self._chaos_fail(section, item_id, action, params, "node param required")
                path = params.get("path", "/var/lib/globular")
                target_pct = int(params.get("target_pct", 95))
                # Calculate how many MB to write: get disk size, compute fill amount
                fill_cmd = (
                    f"df -m {path} | awk 'NR==2{{total=$2; used=$3; free=$4; "
                    f"target=int(total*{target_pct}/100); fill=target-used; "
                    f"if(fill>0) {{system(\"dd if=/dev/zero of={path}/.chaos-fill bs=1M count=\"fill\" status=none\")}} }}'"
                )
                proc = subprocess.run(
                    ["docker", "exec", container, "bash", "-c", fill_cmd],
                    capture_output=True, text=True, timeout=60)
                ok = proc.returncode == 0
                result = {"action": action, "container": container, "path": path,
                          "target_pct": target_pct, "exit_code": proc.returncode,
                          "stderr": proc.stderr.strip()[:200]}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.clear_disk_fill":
                # Remove the chaos fill file created by chaos.fill_disk.
                # params: node, path (default /var/lib/globular)
                if not container:
                    return self._chaos_fail(section, item_id, action, params, "node param required")
                path = params.get("path", "/var/lib/globular")
                proc = subprocess.run(
                    ["docker", "exec", container, "rm", "-f", f"{path}/.chaos-fill"],
                    capture_output=True, text=True, timeout=15)
                ok = proc.returncode == 0
                result = {"action": action, "container": container,
                          "exit_code": proc.returncode}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.block_network":
                # Block all traffic between a node and the rest of the cluster using iptables.
                # params: node, direction (in|out|both, default both)
                # Requires the container to run with NET_ADMIN capability.
                if not container:
                    return self._chaos_fail(section, item_id, action, params, "node param required")
                direction = params.get("direction", "both")
                cmds = []
                if direction in ("out", "both"):
                    cmds.append("iptables -I OUTPUT -j DROP")
                if direction in ("in", "both"):
                    cmds.append("iptables -I INPUT -j DROP")
                # Always allow loopback and etcd health checks from localhost
                cmds.insert(0, "iptables -I OUTPUT -o lo -j ACCEPT")
                cmds.insert(0, "iptables -I INPUT -i lo -j ACCEPT")
                cmd = " && ".join(cmds)
                proc = subprocess.run(
                    ["docker", "exec", "--privileged", container, "bash", "-c", cmd],
                    capture_output=True, text=True, timeout=15)
                ok = proc.returncode == 0
                result = {"action": action, "container": container, "direction": direction,
                          "exit_code": proc.returncode, "stderr": proc.stderr.strip()[:200]}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.unblock_network":
                # Remove iptables DROP rules inserted by chaos.block_network.
                # params: node
                if not container:
                    return self._chaos_fail(section, item_id, action, params, "node param required")
                cmd = "iptables -F INPUT; iptables -F OUTPUT"
                proc = subprocess.run(
                    ["docker", "exec", "--privileged", container, "bash", "-c", cmd],
                    capture_output=True, text=True, timeout=15)
                ok = proc.returncode == 0
                result = {"action": action, "container": container,
                          "exit_code": proc.returncode, "stderr": proc.stderr.strip()[:200]}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.inject_expired_cert":
                # Replace the node's TLS service cert with an expired self-signed cert.
                # The original is saved as service.crt.chaos-backup for restoration.
                # params: node, cert_path (default /var/lib/globular/pki/issued/services/service.crt),
                #         key_path (default /var/lib/globular/pki/issued/services/service.key)
                if not container:
                    return self._chaos_fail(section, item_id, action, params, "node param required")
                cert_path = params.get("cert_path", "/var/lib/globular/pki/issued/services/service.crt")
                key_path = params.get("key_path", "/var/lib/globular/pki/issued/services/service.key")
                # Generate an expired cert (not before/after both in the past)
                gen_cmd = (
                    f"cp {cert_path} {cert_path}.chaos-backup && "
                    f"cp {key_path} {key_path}.chaos-backup && "
                    f"openssl req -x509 -newkey rsa:2048 -keyout {key_path} "
                    f"-out {cert_path} -days 1 -nodes "
                    f"-subj '/CN=chaos-expired' "
                    f"-set_serial 1 "
                    f"2>/dev/null && "
                    # Backdate the cert using faketime if available, otherwise use subjectAltName trickery.
                    # simpler: just write a cert valid from long ago to yesterday.
                    f"openssl req -x509 -newkey rsa:2048 -keyout {key_path} "
                    f"-out {cert_path} -nodes "
                    f"-subj '/CN=chaos-expired' "
                    f"-days 0 "  # 0-day validity = already expired
                    f"2>/dev/null || true"
                )
                proc = subprocess.run(
                    ["docker", "exec", container, "bash", "-c", gen_cmd],
                    capture_output=True, text=True, timeout=30)
                ok = proc.returncode == 0
                result = {"action": action, "container": container, "cert_path": cert_path,
                          "exit_code": proc.returncode, "stderr": proc.stderr.strip()[:300]}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            elif action == "chaos.restore_cert":
                # Restore the original cert after chaos.inject_expired_cert.
                # params: node, cert_path, key_path
                if not container:
                    return self._chaos_fail(section, item_id, action, params, "node param required")
                cert_path = params.get("cert_path", "/var/lib/globular/pki/issued/services/service.crt")
                key_path = params.get("key_path", "/var/lib/globular/pki/issued/services/service.key")
                restore_cmd = (
                    f"[[ -f {cert_path}.chaos-backup ]] && mv {cert_path}.chaos-backup {cert_path}; "
                    f"[[ -f {key_path}.chaos-backup ]] && mv {key_path}.chaos-backup {key_path}; "
                    f"true"
                )
                proc = subprocess.run(
                    ["docker", "exec", container, "bash", "-c", restore_cmd],
                    capture_output=True, text=True, timeout=15)
                ok = proc.returncode == 0
                result = {"action": action, "container": container,
                          "exit_code": proc.returncode}
                self.evidence.record(section, item_id, action, params, {}, result, ok)
                return ok

            else:
                print(f"    SKIP: {item_id} ({action} — unknown chaos action)")
                return True  # unknown chaos = skip, not fail

        except subprocess.TimeoutExpired:
            return self._chaos_fail(section, item_id, action, params, "timed out after 30s")
        except Exception as e:
            return self._chaos_fail(section, item_id, action, params, str(e))

    def _chaos_fail(self, section, item_id, action, params, reason) -> bool:
        result = {"action": action, "error": reason}
        self.evidence.record(section, item_id, action, params, {}, result, False)
        print(f"    ERROR: {item_id} — {reason}")
        return False

    # ── probe dispatch ────────────────────────────────────────────────────────

    def _call_probe(self, probe: str, params: dict) -> dict:
        """
        Call a probe function from probes.sh via bash.
        The probe name "cluster.health" maps to function probe_cluster_health.
        Params dict becomes --key value args.
        """
        func_name = "probe_" + probe.replace(".", "_")

        # Build --key value args from params dict
        args = []
        for k, v in params.items():
            args.extend([f"--{k}", str(v)])

        args_str = " ".join(shlex.quote(a) for a in args)
        cmd = f'source "{PROBES_SH}" && {func_name} {args_str}'

        if self.verbose:
            print(f"    [probe] bash -c '{func_name} {args_str}'")

        try:
            proc = subprocess.run(
                ["bash", "-c", cmd],
                capture_output=True, text=True, timeout=45
            )
            stdout = proc.stdout.strip()
            stderr = proc.stderr.strip()

            if not stdout:
                return {
                    "error": f"probe returned no output (exit {proc.returncode})",
                    "stderr": stderr[:200] if stderr else "",
                }

            try:
                return json.loads(stdout)
            except json.JSONDecodeError:
                # Probe returned non-JSON — treat as raw string
                return {"raw": stdout, "exit_code": proc.returncode}

        except subprocess.TimeoutExpired:
            return {"error": "probe timed out after 45s"}
        except Exception as e:
            return {"error": str(e)}

    # ── expectation checking ──────────────────────────────────────────────────

    def _check_expect(self, result: dict, expect: dict) -> tuple[bool, list]:
        """
        Check result against expect block.
        Supports:
          key: value           — exact equality
          key_gte: N           — numeric >= N (key is the field name without _gte)
          key_lte: N           — numeric <= N
          key_contains: str    — string contains substring
          present: true/false  — dict has/lacks a truthy value
        """
        if not isinstance(result, dict):
            return False, [f"expected dict result, got {type(result).__name__}: {result}"]

        failures = []
        for raw_key, expected_val in expect.items():
            # Determine operator from key suffix
            if raw_key.endswith("_gte"):
                field = raw_key[:-4]
                actual = result.get(field)
                try:
                    if float(actual) < float(expected_val):
                        failures.append(
                            f"field '{field}': expected >= {expected_val}, got {actual}")
                except (TypeError, ValueError):
                    failures.append(
                        f"field '{field}': cannot compare {actual!r} >= {expected_val}")

            elif raw_key.endswith("_lte"):
                field = raw_key[:-4]
                actual = result.get(field)
                try:
                    if float(actual) > float(expected_val):
                        failures.append(
                            f"field '{field}': expected <= {expected_val}, got {actual}")
                except (TypeError, ValueError):
                    failures.append(
                        f"field '{field}': cannot compare {actual!r} <= {expected_val}")

            elif raw_key.endswith("_contains"):
                field = raw_key[:-9]
                actual = result.get(field, "")
                if str(expected_val) not in str(actual):
                    failures.append(
                        f"field '{field}': expected to contain {expected_val!r}, got {actual!r}")

            else:
                # Exact equality
                actual = result.get(raw_key)
                if actual != expected_val:
                    failures.append(
                        f"field '{raw_key}': expected {expected_val!r}, got {actual!r}")

        return len(failures) == 0, failures

    # ── schema validation ─────────────────────────────────────────────────────

    def _validate_schema(self) -> bool:
        required = ["version", "name", "suite"]
        missing = [f for f in required if f not in self.scenario]
        if missing:
            print(f"  ERROR: scenario missing required fields: {missing}", file=sys.stderr)
            return False
        if self.scenario.get("version") != 1:
            print(
                f"  ERROR: unsupported schema version: {self.scenario.get('version')}",
                file=sys.stderr)
            return False
        # Validate optional awareness block if present.
        aw = self.scenario.get("awareness")
        if aw is not None:
            if not isinstance(aw, dict):
                print("  ERROR: 'awareness' must be a mapping", file=sys.stderr)
                return False
            valid_keys = {
                "enabled", "task", "phase", "include_runtime", "runtime_window",
                "create_incident_on_failure", "expected_invariants", "expected_forbidden_fixes",
                "create_proposal_on_failure", "expected_failure_modes", "training",
                "patterns",
            }
            unknown = set(aw.keys()) - valid_keys
            if unknown:
                print(f"  ERROR: unknown keys in awareness block: {sorted(unknown)}",
                      file=sys.stderr)
                return False
            # Validate patterns sub-block
            patterns_cfg = aw.get("patterns")
            if patterns_cfg is not None:
                if not isinstance(patterns_cfg, dict):
                    print("  ERROR: 'awareness.patterns' must be a mapping", file=sys.stderr)
                    return False
                valid_pattern_keys = {"validate", "expected_invariants",
                                      "expected_code_smells_absent", "expected_behavior"}
                unknown_p = set(patterns_cfg.keys()) - valid_pattern_keys
                if unknown_p:
                    print(f"  ERROR: unknown keys in awareness.patterns block: {sorted(unknown_p)}",
                          file=sys.stderr)
                    return False
                KNOWN_PATTERN_IDS = {
                    "pattern.control_plane_data_plane", "pattern.desired_state_reconciliation",
                    "pattern.leased_leadership_single_writer", "pattern.consensus_backed_authority",
                    "pattern.last_known_good", "pattern.circuit_breaker_distributed",
                    "pattern.bulkhead", "pattern.saga_durable_workflow",
                    "pattern.idempotent_executor", "pattern.durable_event_outbox",
                    "pattern.health_gate", "pattern.explicit_degraded_mode",
                    "pattern.fencing_token_generation_guard", "pattern.intent_marker_tombstone",
                    "pattern.read_repair_authority_repair", "pattern.backpressure",
                    "pattern.bootstrap_then_promote", "pattern.dns_independent_recovery",
                    "pattern.split_brain_prevention", "pattern.bounded_critical_query",
                    # legacy patterns.yaml entries
                    "pattern.persistence_gap", "pattern.error_swallowing",
                    "pattern.stale_authority", "pattern.partial_truth",
                    "pattern.unverified_runtime_truth", "pattern.unbounded_critical_query",
                    "pattern.destructive_absence", "pattern.missing_intent_marker",
                    "pattern.version_only_identity",
                    "pattern.runtime_observation_as_desired_authority",
                    "pattern.ephemeral_state_contamination", "pattern.unit_type_shadowing",
                }
                for pid in (patterns_cfg.get("validate") or []):
                    if not str(pid).startswith("pattern."):
                        print(f"  ERROR: pattern ID must start with 'pattern.': {pid}",
                              file=sys.stderr)
                        return False
                    if pid not in KNOWN_PATTERN_IDS:
                        print(f"  ERROR: unknown pattern ID: {pid}", file=sys.stderr)
                        return False
        return True

    # ── output ────────────────────────────────────────────────────────────────

    def _awareness_artifact_status(self) -> dict:
        """Return a status dict for each awareness artifact type."""
        adir = os.path.join(self.output_dir, "awareness")
        if not os.path.isdir(adir):
            return {}
        skipped = os.path.exists(os.path.join(adir, "SKIPPED.txt"))

        def _status(base_names, error_names=None):
            if skipped:
                return "SKIPPED"
            for n in (base_names if isinstance(base_names, list) else [base_names]):
                if os.path.exists(os.path.join(adir, n)):
                    return "PASS"
            for n in (error_names or []):
                if os.path.exists(os.path.join(adir, n)):
                    return "ERROR"
            return "SKIPPED"

        incident_status = "SKIPPED"
        if not skipped:
            if os.path.exists(os.path.join(adir, "incident.yaml")):
                incident_status = "CREATED"
            elif os.path.exists(os.path.join(adir, "incident.error.txt")):
                incident_status = "ERROR"

        proposal_status = "SKIPPED"
        if not skipped:
            if os.path.exists(os.path.join(adir, "proposal.yaml")):
                proposal_status = "DRAFT"
            elif os.path.exists(os.path.join(adir, "proposal.error.txt")):
                proposal_status = "ERROR"

        return {
            "preflight": _status(
                ["preflight.agent.txt", "preflight.json"]),
            "debug-session": _status(
                ["debug-session.agent.txt", "debug-session.json"]),
            "runtime-snapshot": _status(
                ["runtime-snapshot.json"],
                ["runtime-snapshot.error.txt"]),
            "incident": incident_status,
            "proposal": proposal_status,
        }

    def _write_patterns_md(self, pattern_result: str) -> None:
        """Write PATTERNS.md summarizing pattern validation evidence."""
        patterns_md_path = os.path.join(self.output_dir, "PATTERNS.md")
        adir = os.path.join(self.output_dir, "awareness")
        val_file = os.path.join(adir, "patterns", "validation.json")

        val = {}
        if os.path.exists(val_file):
            try:
                with open(val_file) as f:
                    val = json.load(f)
            except Exception:
                pass

        # Gather evidence presence
        preflight_present = os.path.exists(os.path.join(adir, "preflight.json"))
        debug_present = os.path.exists(os.path.join(adir, "debug-session.json"))

        # Extract matched data from preflight if available
        pf_invariants: list = []
        pf_fail_modes: list = []
        pf_forbidden: list = []
        pf_code_smells: list = []
        if preflight_present:
            try:
                with open(os.path.join(adir, "preflight.json")) as fh:
                    pf = json.load(fh)
                pf_invariants = pf.get("matched_invariants") or pf.get("invariants") or []
                pf_fail_modes = pf.get("matched_failure_modes") or pf.get("failure_modes") or []
                pf_forbidden = pf.get("forbidden_fixes") or []
                pf_code_smells = pf.get("code_smells") or []
            except Exception:
                pass

        patterns_tested = self.awareness.patterns_validate
        expected_invariants = self.awareness.expected_invariants_for_patterns
        expected_smells_absent = self.awareness.expected_code_smells_absent
        patterns_matched = val.get("patterns_with_output") or []
        patterns_missing = val.get("patterns_missing") or []

        missing_evidence = []
        if not preflight_present:
            missing_evidence.append("preflight.json")
        if not debug_present:
            missing_evidence.append("debug-session.json")
        if patterns_missing:
            missing_evidence.extend([f"pattern output for {p}" for p in patterns_missing])

        with open(patterns_md_path, "w") as f:
            f.write("# Pattern Validation\n\n")

            f.write("## Patterns tested\n\n")
            if patterns_tested:
                for p in patterns_tested:
                    f.write(f"- {p}\n")
            else:
                f.write("- (none)\n")
            f.write("\n")

            f.write("## Expected invariants\n\n")
            if expected_invariants:
                for inv in expected_invariants:
                    f.write(f"- {inv}\n")
            else:
                f.write("- (none specified)\n")
            f.write("\n")

            f.write("## Expected code smells absent\n\n")
            if expected_smells_absent:
                for s in expected_smells_absent:
                    f.write(f"- {s}\n")
            else:
                f.write("- (none specified)\n")
            f.write("\n")

            f.write("## Runtime evidence\n\n")
            f.write(f"- preflight.json: {'present' if preflight_present else 'absent'}\n")
            f.write(f"- debug-session.json: {'present' if debug_present else 'absent'}\n")
            f.write("\n")

            f.write("## Awareness matches\n\n")
            f.write(f"- patterns: {patterns_matched if patterns_matched else '(none matched)'}\n")
            if pf_invariants:
                f.write(f"- invariants: {pf_invariants[:5]}"
                        f"{'...' if len(pf_invariants) > 5 else ''}\n")
            else:
                f.write("- invariants: (none)\n")
            if pf_fail_modes:
                f.write(f"- failure modes: {pf_fail_modes[:5]}"
                        f"{'...' if len(pf_fail_modes) > 5 else ''}\n")
            else:
                f.write("- failure modes: (none)\n")
            if pf_forbidden:
                f.write(f"- forbidden fixes: {pf_forbidden[:5]}"
                        f"{'...' if len(pf_forbidden) > 5 else ''}\n")
            else:
                f.write("- forbidden fixes: (none)\n")
            if pf_code_smells:
                f.write(f"- code smells: {pf_code_smells[:5]}"
                        f"{'...' if len(pf_code_smells) > 5 else ''}\n")
            else:
                f.write("- code smells: (none)\n")
            f.write("\n")

            f.write(f"## Result\n\n{pattern_result}\n\n")

            f.write("## Notes\n\n")
            f.write("- lab-only topology: single-node quickstart"
                    " (not full 3-node production cluster)\n")
            if missing_evidence:
                for m in missing_evidence:
                    f.write(f"- missing evidence: {m}\n")
            rec = val.get("recommended_next_scenario") or ""
            if rec:
                f.write(f"- recommended next scenario: {rec}\n")

    def _write_output(self, passed: bool, result: str = "", awareness_result: str = ""):
        os.makedirs(self.output_dir, exist_ok=True)
        result = result or ("PASS" if passed else "FAIL")

        # evidence.json
        ev = self.evidence.to_dict()
        ev["passed"] = passed
        ev["result"] = result
        ev["awareness_result"] = awareness_result or "AWARENESS_SKIPPED"
        with open(os.path.join(self.output_dir, "evidence.json"), "w") as f:
            json.dump(ev, f, indent=2)

        # RESULT.md
        pass_count = sum(1 for i in ev["items"] if i.get("passed"))
        fail_count = len(ev["items"]) - pass_count
        awareness_status = self._awareness_artifact_status()

        # Parse matched invariants/failure modes from awareness JSON artifacts
        matched_inv: list = []
        matched_fm: list = []
        learning_rec = ""
        adir = os.path.join(self.output_dir, "awareness")
        for fname in ("preflight.json", "debug-session.json"):
            fpath = os.path.join(adir, fname)
            if os.path.exists(fpath):
                try:
                    with open(fpath) as fh:
                        d = json.load(fh)
                    for item in (d.get("matched_invariants") or d.get("invariants") or []):
                        n = item if isinstance(item, str) else (item.get("id") or str(item))
                        if n and n not in matched_inv:
                            matched_inv.append(n)
                    for item in (d.get("matched_failure_modes") or d.get("failure_modes") or []):
                        n = item if isinstance(item, str) else (item.get("id") or str(item))
                        if n and n not in matched_fm:
                            matched_fm.append(n)
                    if not learning_rec:
                        learning_rec = (d.get("learning_recommendation")
                                        or d.get("recommendation") or "")
                except Exception:
                    pass

        with open(os.path.join(self.output_dir, "RESULT.md"), "w") as f:
            f.write(f"# {ev['scenario']}\n\n")
            f.write(f"**Suite**: {ev['suite']}  \n")
            f.write(f"**Result**: {result}  \n")
            f.write(f"**Awareness**: {awareness_result or 'AWARENESS_SKIPPED'}  \n")
            f.write(f"**Time**: {ev['start_time']}  \n")
            f.write(f"**Checks**: {pass_count} passed, {fail_count} failed\n\n")

            if ev["items"]:
                f.write("## Checks\n\n")
                f.write("| Section | ID | Probe | Result |\n")
                f.write("|---------|----|----|--------|\n")
                for item in ev["items"]:
                    icon = "✓" if item.get("passed") else "✗"
                    f.write(
                        f"| {item['section']} | {item['id']} | {item['probe']} | {icon} |\n")

            if awareness_status:
                f.write("\n## Awareness\n\n")
                f.write("| Artifact | Status |\n")
                f.write("|----------|--------|\n")
                for key, status in awareness_status.items():
                    f.write(f"| {key} | {status} |\n")

                if matched_inv:
                    f.write(f"\n**Matched invariants**: {', '.join(matched_inv[:5])}")
                    if len(matched_inv) > 5:
                        f.write(f" (+{len(matched_inv)-5} more)")
                    f.write("\n")
                if matched_fm:
                    f.write(f"**Matched failure modes**: {', '.join(matched_fm[:5])}")
                    if len(matched_fm) > 5:
                        f.write(f" (+{len(matched_fm)-5} more)")
                    f.write("\n")
                if learning_rec:
                    f.write(f"**Recommendation**: {learning_rec[:120]}\n")

                adir_rel = "awareness"
                f.write(f"\nArtifacts: `{adir_rel}/`\n")
                for fname, label in [
                    ("preflight.agent.txt", "preflight.agent.txt"),
                    ("debug-session.agent.txt", "debug-session.agent.txt"),
                    ("runtime-snapshot.json", "runtime-snapshot.json"),
                    ("incident.yaml", "incident.yaml"),
                    ("proposal.yaml", "proposal.yaml [DRAFT — manual review required]"),
                ]:
                    if os.path.exists(os.path.join(self.output_dir, adir_rel, fname)):
                        f.write(f"- [{label}]({adir_rel}/{fname})\n")

                if os.path.exists(os.path.join(self.output_dir, adir_rel, "proposal.yaml")):
                    f.write("\n> **DRAFT PROPOSAL** — manual review required before approval.\n")
                    f.write("> Run: `globular awareness validate-proposal --file "
                            f"{adir_rel}/proposal.yaml`\n")

        # Write PATTERNS.md if patterns block is configured (always, even if SKIPPED)
        if self.awareness.patterns_validate is not None:
            pattern_result = getattr(self.awareness, "_pattern_result", "SKIPPED")
            self._write_patterns_md(pattern_result)
            patterns_md = os.path.join(self.output_dir, "PATTERNS.md")
            if os.path.exists(patterns_md):
                with open(os.path.join(self.output_dir, "RESULT.md"), "a") as rf:
                    rf.write(f"\n## Pattern Validation\n\n")
                    rf.write(f"**Pattern result**: {pattern_result}  \n")
                    rf.write(f"See [PATTERNS.md](PATTERNS.md) for full pattern evidence.\n")

        if self.baseline_captures:
            with open(os.path.join(self.output_dir, "RESULT.md"), "a") as f:
                f.write("\n## Baseline Captures\n\n```json\n")
                f.write(json.dumps(self.baseline_captures, indent=2))
                f.write("\n```\n")

    def _append_to_ledger(self, result: str, awareness_result: str) -> None:
        if not os.path.exists(TRAINING_SH):
            return
        scenario_name = self.scenario.get("name", "unknown")
        task = self.awareness.task or ""
        phase = self.awareness.phase or ""
        run_id = os.path.basename(self.output_dir)
        adir = os.path.join(self.output_dir, "awareness")
        incident_created = "true" if os.path.exists(
            os.path.join(adir, "incident.yaml")) else "false"
        proposal_created = "true" if os.path.exists(
            os.path.join(adir, "proposal.yaml")) else "false"
        awareness_status = awareness_result.replace("AWARENESS_", "")
        cmd = (
            f'source "{TRAINING_SH}" && '
            f'training_ledger_append '
            f'{shlex.quote(LEDGER_FILE)} '
            f'{shlex.quote(run_id)} '
            f'{shlex.quote(scenario_name)} '
            f'{shlex.quote(result)} '
            f'{shlex.quote(awareness_status)} '
            f'{shlex.quote(task)} '
            f'{shlex.quote(phase)} '
            f'{shlex.quote(incident_created)} '
            f'{shlex.quote(proposal_created)} '
            f'{shlex.quote(self.output_dir)}'
        )
        try:
            subprocess.run(["bash", "-c", cmd], timeout=30)
        except Exception as e:
            print(f"  [training] WARNING: ledger append error: {e}")

        # Pattern ledger — written separately if patterns were tested
        if self.awareness.patterns_validate:
            self._append_to_pattern_ledger(result)

    def _append_to_pattern_ledger(self, scenario_result: str) -> None:
        """Append one JSON line to the pattern-specific ledger."""
        pattern_ledger = os.path.join(
            os.path.dirname(LEDGER_FILE), "awareness-pattern-ledger.jsonl")
        adir = os.path.join(self.output_dir, "awareness")
        val_file = os.path.join(adir, "patterns", "validation.json")

        val = {}
        if os.path.exists(val_file):
            try:
                with open(val_file) as f:
                    val = json.load(f)
            except Exception:
                pass

        # Extract data from preflight.json for enrichment
        pf_code_smells: list = []
        pf_forbidden: list = []
        pf_invariants: list = []
        pf_path = os.path.join(adir, "preflight.json")
        if os.path.exists(pf_path):
            try:
                with open(pf_path) as fh:
                    pf = json.load(fh)
                pf_code_smells = pf.get("code_smells") or []
                pf_forbidden = pf.get("forbidden_fixes") or []
                pf_invariants = pf.get("matched_invariants") or pf.get("invariants") or []
            except Exception:
                pass

        patterns_tested = self.awareness.patterns_validate
        patterns_matched = val.get("patterns_with_output") or []
        pattern_result = getattr(self.awareness, "_pattern_result", "SKIPPED")
        scenario_name = self.scenario.get("name", "unknown")
        run_id = os.path.basename(self.output_dir)
        ts = datetime.datetime.utcnow().isoformat() + "Z"

        entry = {
            "run_id": run_id,
            "scenario": scenario_name,
            "timestamp": ts,
            "patterns_tested": patterns_tested,
            "patterns_matched": patterns_matched,
            "pattern_result": pattern_result,
            "code_smells": pf_code_smells[:10],
            "forbidden_fixes": pf_forbidden[:10],
            "new_failure_class": False,
            "matched_invariants": pf_invariants[:10],
            "scenario_result": scenario_result,
        }
        try:
            os.makedirs(os.path.dirname(pattern_ledger), exist_ok=True)
            with open(pattern_ledger, "a") as f:
                f.write(json.dumps(entry) + "\n")
            print(f"  [training] pattern-ledger: {pattern_ledger}")
        except Exception as e:
            print(f"  [training] WARNING: pattern ledger append error: {e}")


# ── main ──────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    verbose = "--verbose" in args or "-v" in args
    args = [a for a in args if a not in ("--verbose", "-v")]

    if len(args) < 2:
        print(f"Usage: globular-scenario <scenario.yaml> <output-dir> [--verbose]",
              file=sys.stderr)
        sys.exit(1)

    scenario_file = args[0]
    output_dir = args[1]

    if not os.path.exists(scenario_file):
        print(f"ERROR: scenario not found: {scenario_file}", file=sys.stderr)
        sys.exit(1)

    os.makedirs(output_dir, exist_ok=True)

    executor = ScenarioExecutor(scenario_file, output_dir, verbose)
    passed = executor.run()
    sys.exit(0 if passed else 1)


if __name__ == "__main__":
    main()
